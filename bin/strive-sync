#!/bin/bash

# ============================================================================
# STRIVE-SYNC: Mission Control for Your Workspace
# Parallel Repository Synchronizer with Live Dashboard
#
# 🚀 Strive-Sync (v1.3.0)
# A Striving Designs open-source tool — strivingdesigns.com
# Built by Prayas Shrestha · github.com/prayasshr/strive-cli
# License: MIT
# ============================================================================
#
# ARCHITECTURE
#   Main process   → parses flags, discovers repos, dispatches workers
#   Worker jobs    → one background process per repo; writes status to $STATUS_DIR
#   Dashboard job  → reads $STATUS_DIR files every 200ms, redraws the HUD
#   Cleanup (trap) → removes $STATUS_DIR/active to signal the dashboard, then
#                    calls `wait $DASHBOARD_PID` (not sleep+kill) so the final
#                    render completes before anything else prints to stdout
# ============================================================================

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
    SOURCE=$(readlink "$SOURCE")
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"

if [ -f "$SCRIPT_DIR/../lib/common.sh" ]; then
    source "$SCRIPT_DIR/../lib/common.sh"
    [ -f "$SCRIPT_DIR/../lib/interactive.sh" ] && source "$SCRIPT_DIR/../lib/interactive.sh"
else
    echo "Error: lib/common.sh not found (resolved script dir: $SCRIPT_DIR)"
    exit 1
fi

# Auto-read version from the nearest annotated git tag on an exact match.
# To release: git tag v1.0.2 -m "..." && git push --tags
_TAGGED=$(git -C "$SCRIPT_DIR" describe --tags --exact-match 2>/dev/null)
VERSION="${_TAGGED#v}"
[ -z "$VERSION" ] && VERSION="1.3.0"

CONFIG_FILE=".repos"
MAX_PARALLEL=4

MISSION_TITLE="STRIVE-SYNC MISSION CONTROL"
BATT_ICON=$(get_power_icon)

START_TIME=$(perl -e 'use Time::HiRes qw(time); print time' 2>/dev/null || date +%s)

# XDG-compliant state dir — keeps $HOME clean
MEMORY_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/strive-sync"
MEMORY_FILE="$MEMORY_DIR/last_sync"
mkdir -p "$MEMORY_DIR"

STATUS_DIR=$(mktemp -d -t strive_sync.XXXXXX) || exit 1
LOG_DIR=$(mktemp -d -t strive_sync_logs.XXXXXX) || exit 1
AUDIT_DIR=$(mktemp -d -t strive_sync_audit.XXXXXX) || exit 1

if [ -f "$MEMORY_FILE" ]; then
    LAST_TIME=$(awk '{print $1}' "$MEMORY_FILE")
    LAST_STATUS=$(awk '{$1=""; print $0}' "$MEMORY_FILE" | sed 's/^ //')
    rel=$(get_relative_time "$LAST_TIME")
    LAST_MISSION_STR="LAST MISSION: $rel ($LAST_STATUS)"
else
    LAST_MISSION_STR="LAST MISSION: Never"
fi

# Prevent git from hanging on credential prompts inside background workers
export GIT_TERMINAL_PROMPT=0
export GIT_SSH_COMMAND="ssh -o BatchMode=yes"

AUTO_INSTALL=false
FORCE_SYNC=false
DRY_RUN=false
BRANCH_OVERRIDDEN=false
MIGRATE_TO_MAIN=false
NON_INTERACTIVE=false
EXCLUDED_REPOS=()
EXCLUSIVE_REPO=""
AUDIT_ENABLED=false
AUDIT_FILE="AUDIT.md"

show_help() {
    echo -e "${CYAN}${BOLD}STRIVE-SYNC | v$VERSION${NC} - Workspace Mission Control\n"
    echo -e "Usage: strive-sync [options]"
    echo ""
    echo -e "${YELLOW}${BOLD}Options:${NC}"
    echo -e "  -o, --only <repo>       Sync ONLY this specific repository"
    echo -e "  -e, --exclude <repo>    Exclude a specific repository from syncing"
    echo -e "  -b, --branch <name>     Override auto-detected branch for all repos"
    echo -e "  -d, --dry-run           Dryrun: show changes without making them"
    echo -e "  -i, --install           Install packages if lockfiles changed"
    echo -e "  -m, --main              Switch to Main branch before syncing"
    echo -e "  -f, --force             Force Everything: pull and reinstall even if up-to-date"
    echo -e "  -a, --audit             Generate AUDIT.md in the current directory"
    echo -e "  -p, --parallel <num>    Max parallel processes (default: 4)"
    echo -e "  -y, --yes               Non-interactive mode: bypass interactive briefing"
    echo -e "  -v, --version           Show version and exit"
    echo -e "  -h, --help              Show this help menu"
    echo ""
    echo -e "${CYAN}${BOLD}Discovery:${NC}"
    echo -e "  Run from any directory containing Git repositories."
    echo -e "  Create a ${BOLD}.repos${NC} file for explicit repo:branch control."
    echo ""
    echo -e "  --"
    echo -e "  A ${CYAN}Striving Designs${NC} open-source tool · strivingdesigns.com"
    echo -e "  by Prayas Shrestha · github.com/prayasshr"
    echo ""
}

# Determines a repo's default branch without hardcoding main/master.
# 1. Reads refs/remotes/origin/HEAD (local, zero network)
# 2. Falls back to `git remote show origin` (one network round-trip)
detect_default_branch() {
    local repo=$1
    local branch
    branch=$(git -C "$repo" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
             | sed 's|^refs/remotes/origin/||')
    if [ -z "$branch" ]; then
        branch=$(git -C "$repo" remote show origin 2>/dev/null \
                 | awk '/HEAD branch/ {print $NF}')
    fi
    echo "${branch:-main}"
}

# Worker function — runs as a background job, one per repo.
# Writes status updates to $STATUS_DIR; never touches stdout directly.
process_sync() {
    local repo_info=$1
    local repo=$(echo "$repo_info" | cut -d: -f1)
    local branch_in_file=$(echo "$repo_info" | cut -d: -f2)
    local log_file="$LOG_DIR/$(echo "$repo" | sed 's|/|__|g').log"

    # Branch precedence: .repos file → -b flag → auto-detected remote HEAD
    local target_branch
    if [ "$branch_in_file" != "$repo" ]; then
        target_branch="$branch_in_file"
    elif [ "$BRANCH_OVERRIDDEN" == "true" ]; then
        target_branch="$DEFAULT_BRANCH"
    else
        target_branch=$(detect_default_branch "$repo")
    fi

    # Audit Header
    update_audit "$repo" "### Repo: **$repo**"
    update_audit "$repo" "Target Branch: \`$target_branch\`"

    local current_branch=$(git -C "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null)
    local original_branch="$current_branch"
    local migration_status=""

    update_status "$repo" "${CYAN}[STARTING]${NC} Initializing..."

    if [ ! -d "$repo" ]; then
        update_status "$repo" "${RED}[MISSING ]${NC} Directory not found"
        return 1
    fi

    # Leave dirty repos untouched — developer must resolve manually
    if [ -n "$(git -C "$repo" status --short)" ]; then
        update_status "$repo" "${YELLOW}[DIRTY   ]${NC} $current_branch"
        update_audit "$repo" "Status: [DIRTY] - Local changes found. Skipping sync."
        return 0
    fi

    # [V1.1] Smart Switch: Migrating to target branch if clean
    if [ "$MIGRATE_TO_MAIN" == "true" ] && [ "$current_branch" != "$target_branch" ]; then
        if [ "$DRY_RUN" == "true" ]; then
            update_status "$repo" "${CYAN}[CHECKOUT]${NC} (DRY RUN) $original_branch ➔ $target_branch"
            current_branch="$target_branch"
            migration_status="$original_branch ➔ "
        else
            update_status "$repo" "${CYAN}[CHECKOUT]${NC} $original_branch ➔ $target_branch"
            if git -C "$repo" checkout "$target_branch" >> "$log_file" 2>&1; then
                current_branch="$target_branch"
                migration_status="$original_branch ➔ "
                update_audit "$repo" "Action: Checked out target branch \`$target_branch\` (was \`$original_branch\`)."
            else
                update_status "$repo" "${RED}[SKIP-DIR]${NC} $current_branch (dirty?)"
                return 1
            fi
        fi
    fi

    if [ "$DRY_RUN" == "true" ]; then
        update_status "$repo" "${CYAN}[FETCHING]${NC} (DRY RUN) $current_branch"
        sleep 0.5
    else
        update_status "$repo" "${CYAN}[FETCHING]${NC} $current_branch..."
        if ! git -C "$repo" fetch --quiet origin "$target_branch" 2>"$log_file"; then
            update_status "$repo" "${RED}[FAILED  ]${NC} Fetch error"
            return 1
        fi
    fi

    if [ "$DRY_RUN" == "true" ] && [ "$MIGRATE_TO_MAIN" == "true" ]; then
        # In dry run migration, compare the actual target branch hash (if it exists) to remote
        LOCAL=$(git -C "$repo" rev-parse "$target_branch" 2>/dev/null || git -C "$repo" rev-parse HEAD 2>/dev/null)
    else
        LOCAL=$(git -C "$repo" rev-parse HEAD 2>/dev/null)
    fi

    # Upstream calculation for the target branch
    UPSTREAM=$(git -C "$repo" rev-parse --abbrev-ref "$target_branch"@{u} 2>/dev/null || echo "origin/$target_branch")
    REMOTE=$(git -C "$repo" rev-parse "$UPSTREAM" 2>/dev/null)

    if [ "$LOCAL" == "$REMOTE" ]; then
        # Already in sync — show SYNCED regardless of force mode.
        # With -f we do NOT return early; we fall through to the install block below.
        update_status "$repo" "${GREEN}[SYNCED  ]${NC} $migration_status$current_branch"
        update_audit "$repo" "Git: [SYNCED] - Already at commit \`${LOCAL:0:7}\`."
        [ "$FORCE_SYNC" == "false" ] && return 0
    fi

    # Only fast-forward — never rebase or reset automatically
    if [ "$DRY_RUN" == "true" ]; then
        update_status "$repo" "${BLUE}[UPDATING]${NC} (DRY RUN) Merging..."
        sleep 0.5
    elif [ "$LOCAL" != "$REMOTE" ] && git -C "$repo" merge-base --is-ancestor "$REMOTE" "$LOCAL" 2>/dev/null; then
        update_status "$repo" "${GREEN}[SUCCESS ]${NC} $migration_status$current_branch (ahead)"
    elif git -C "$repo" merge-base --is-ancestor "$LOCAL" "$REMOTE" 2>/dev/null; then
        update_status "$repo" "${BLUE}[UPDATING]${NC} Fast-forwarding..."
        git -C "$repo" merge --quiet --ff-only "$UPSTREAM" >> "$log_file" 2>&1
        update_audit "$repo" "Git: [SUCCESS] - Fast-forwarded to \`$UPSTREAM\` (\`${REMOTE:0:7}\`)."
    else
        update_status "$repo" "${RED}[OUT SYNC]${NC} $migration_status$current_branch (rebase req)"
        update_audit "$repo" "Git: [OUT SYNC] - Diversion found. Manual rebase required."
        return 1
    fi

    # Dependency install is opt-in (-i or -f) — never runs silently by default

    if [ "$AUTO_INSTALL" == "false" ] && [ "$FORCE_SYNC" == "false" ]; then
        update_status "$repo" "${GREEN}[SUCCESS ]${NC} $migration_status$current_branch"
        return 0
    fi

    if ! git -C "$repo" diff --quiet HEAD@{1} HEAD \
         -- yarn.lock package-lock.json pnpm-lock.yaml bun.lockb package.json \
         2>>"$log_file" \
         || [ "$FORCE_SYNC" == "true" ]; then

        if [ "$DRY_RUN" == "true" ]; then

            update_status "$repo" "${PURPLE}[DEPS    ]${NC} (DRY RUN) Installing..."
            sleep 0.5
            update_status "$repo" "${GREEN}[SUCCESS ]${NC} $migration_status$current_branch (dry run)"
        else
            # Honour .nvmrc / .node-version before touching any lockfile.
            # A version mismatch here is the most common cause of silent install failures.
            ensure_node_version "$repo" "$log_file"
            if [ -f "$repo/.nvmrc" ]; then
                update_audit "$repo" "Node: Loaded version from \`.nvmrc\` (\`$(cat "$repo/.nvmrc")\`)."
            elif [ -f "$repo/.node-version" ]; then
                update_audit "$repo" "Node: Loaded version from \`.node-version\` (\`$(cat "$repo/.node-version")\`)."
            fi

            # Pick the package manager by the most recently modified lockfile
            NEWEST_LOCK=$(ls -1t \
                "$repo"/yarn.lock "$repo"/package-lock.json \
                "$repo"/pnpm-lock.yaml "$repo"/bun.lockb 2>/dev/null | head -n 1)

            if [[ "$NEWEST_LOCK" == *"yarn.lock" ]]; then
                update_status "$repo" "${PURPLE}[YARN    ]${NC} Installing..."
                (cd "$repo" || return; yarn --silent --non-interactive) >> "$log_file" 2>&1
                update_status "$repo" "${GREEN}[SUCCESS ]${NC} $migration_status$current_branch + yarn"
                update_audit "$repo" "Deps: [SUCCESS] - Updated dependencies with **Yarn**."
            elif [[ "$NEWEST_LOCK" == *"pnpm-lock.yaml" ]]; then
                update_status "$repo" "${PURPLE}[PNPM    ]${NC} Installing..."
                (cd "$repo" || return; pnpm install --silent) >> "$log_file" 2>&1
                update_status "$repo" "${GREEN}[SUCCESS ]${NC} $migration_status$current_branch + pnpm"
                update_audit "$repo" "Deps: [SUCCESS] - Updated dependencies with **pnpm**."
            elif [[ "$NEWEST_LOCK" == *"bun.lockb" ]]; then
                update_status "$repo" "${PURPLE}[BUN     ]${NC} Installing..."
                (cd "$repo" || return; bun install --silent) >> "$log_file" 2>&1
                update_status "$repo" "${GREEN}[SUCCESS ]${NC} $migration_status$current_branch + bun"
                update_audit "$repo" "Deps: [SUCCESS] - Updated dependencies with **Bun**."
            elif [[ "$NEWEST_LOCK" == *"package-lock.json" ]] || [ -f "$repo/package.json" ]; then
                update_status "$repo" "${PURPLE}[NPM     ]${NC} Installing..."
                (cd "$repo" || return; npm install --silent) >> "$log_file" 2>&1
                update_status "$repo" "${GREEN}[SUCCESS ]${NC} $migration_status$current_branch + npm"
                update_audit "$repo" "Deps: [SUCCESS] - Updated dependencies with **NPM**."
            else
                # No supported package manager found — mark as success to clear the [UPDATING] status
                update_status "$repo" "${GREEN}[SUCCESS ]${NC} $migration_status$current_branch"
                update_audit "$repo" "Deps: [SKIP] - No supported package manager found."
            fi
        fi
    else
        update_status "$repo" "${GREEN}[SUCCESS ]${NC} $migration_status$current_branch"
    fi
}

# ============================================================================
# MAIN
# ============================================================================

ORIG_ARG_COUNT=$#
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -h|--help)     show_help; exit 0 ;;
        -v|--version)  echo "strive-sync v$VERSION · A Striving Designs tool by Prayas Shrestha · strivingdesigns.com"; exit 0 ;;
        -p|--parallel) MAX_PARALLEL="$2"; shift ;;
        -b|--branch)   DEFAULT_BRANCH="$2"; BRANCH_OVERRIDDEN=true; shift ;;
        -o|--only)     EXCLUSIVE_REPO="$2"; shift ;;
        -i|--install)  AUTO_INSTALL=true ;;
        -m|--main)     MIGRATE_TO_MAIN=true ;;
        -f|--force)    FORCE_SYNC=true ;;
        -d|--dry-run)  DRY_RUN=true ;;
        -a|--audit)    AUDIT_ENABLED=true ;;
        -e|--exclude)  EXCLUDED_REPOS+=("$2"); shift ;;
        -y|--yes)      NON_INTERACTIVE=true ;;
        *) echo -e "${RED}Unknown parameter: $1${NC}"; show_help; exit 1 ;;
    esac
    shift
done

[ -z "$DEFAULT_BRANCH" ] && DEFAULT_BRANCH="main"

is_excluded() {
    local target="$1"
    for ex in "${EXCLUDED_REPOS[@]}"; do
        [[ "$target" == "$ex" ]] && return 0
    done
    return 1
}

# Discovery: --only → .repos file → auto-find .git dirs (up to depth 5)
# No automatic parent-directory pivot — if no repos are found here, we say so.
if [ -n "$EXCLUSIVE_REPO" ]; then
    REPOS=("$EXCLUSIVE_REPO")
elif [ -f "$CONFIG_FILE" ]; then
    REPOS=()
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        is_excluded "$line" && continue
        REPOS+=("$line")
    done < "$CONFIG_FILE"
else
    REPOS=()
    echo -ne "${CYAN}Scanning workspace...${NC}\r"
    while IFS= read -r dir; do
        is_excluded "$dir" && continue
        REPOS+=("$dir")
    done < <(find . -maxdepth 5 \( -name "node_modules" -o -name ".next" -o -name "vendor" \) -prune -o -name ".git" -type d -print 2>/dev/null \
             | sed 's|/\.git$||' | sed 's|^\./||' | sort -u)
    echo -ne "\033[K" # Clear the scanning message
fi

if [ ${#REPOS[@]} -eq 0 ]; then
    echo -e "${YELLOW}No Git repositories found in the current directory.${NC}"
    echo -e "Tip: Run from your workspace root, or create a ${BOLD}.repos${NC} file."
    exit 1
fi

# INTERACTIVE MISSION BRIEFING (Pre-flight Review)
# Triggered if in a terminal and not explicitly silenced with -y/--yes.
if [ "$NON_INTERACTIVE" == "false" ] && [ -t 0 ]; then
    show_mission_briefing "$MIGRATE_TO_MAIN" "$AUTO_INSTALL" "$FORCE_SYNC" "$DRY_RUN" "${REPOS[@]}"
fi

touch "$STATUS_DIR/active"
for repo_info in "${REPOS[@]}"; do
    repo=$(echo "$repo_info" | cut -d: -f1)
    update_status "$repo" "${NC}[WAITING ] Waiting...${NC}"
done

render_dashboard &
DASHBOARD_PID=$!

cleanup() {
    kill "${WORKER_PIDS[@]}" 2>/dev/null

    # Let workers flush their final status writes before the dashboard renders
    sleep 0.5
    rm -f "$STATUS_DIR/active"

    # Wait for the dashboard's final render to finish — do NOT use sleep+kill.
    # A premature kill leaves the cursor mid-block, causing the MISSION COMPLETE
    # line to overwrite repo rows (the "accordion collapse" bug).
    wait $DASHBOARD_PID 2>/dev/null
    safe_tput cnorm 2>/dev/null

    END_TIME=$(perl -e 'use Time::HiRes qw(time); print time' 2>/dev/null || date +%s)
    ELAPSED=$(echo "$END_TIME - $START_TIME" | bc 2>/dev/null \
              || echo "$((END_TIME - START_TIME))")
    [[ $ELAPSED == *"."* ]] && ELAPSED=$(printf "%.2f" "$ELAPSED")

    local final_status="Success"
    if [ -d "$STATUS_DIR" ]; then
        if grep -qE '\[FAILED  \]|\[MISSING \]|\[OUT SYNC\]' "$STATUS_DIR"/* 2>/dev/null; then
            final_status="Completed with errors"
        elif grep -q '\[DIRTY   \]' "$STATUS_DIR"/* 2>/dev/null; then
            final_status="Success (Dirty)"
        fi
    fi
    echo "$(date +%s) $final_status" > "$MEMORY_FILE"

    # Synthesis of the Mission Audit Log
    if [ "$AUDIT_ENABLED" == "true" ]; then
        {
            echo "# 🚀 STRIVE-SYNC AUDIT"
            echo "Generated: $(date '+%Y-%m-%d %H:%M:%S')"
            echo ""
            echo "## 📊 Mission Summary"
            echo "- **Status**: $final_status"
            echo "- **Duration**: ${ELAPSED}s"
            echo "- **User**: $USER"
            echo "- **Workspace**: $(pwd)"
            echo ""
            echo "## 🛡️ Repository Details"
            echo ""
            # Sort and append all worker snippets
            for snippet in $(ls "$AUDIT_DIR"/*.md 2>/dev/null | sort); do
                cat "$snippet"
                echo ""
                echo "---"
                echo ""
            done
            echo "Generated by Striving Designs · strivingdesigns.com"
        } > "$AUDIT_FILE"
    fi

    rm -rf "$STATUS_DIR" "$LOG_DIR" "$AUDIT_DIR"
    echo -e "\n${BLUE}────────────────────────────────────────────────────────────${NC}"
    echo -e "${CYAN}${BOLD}MISSION COMPLETE in ${ELAPSED}s${NC}"
    [ "$AUDIT_ENABLED" == "true" ] && echo -e "${YELLOW}Audit report saved to: ${BOLD}$AUDIT_FILE${NC}"
}
trap cleanup EXIT INT TERM

WORKER_PIDS=()
for repo_info in "${REPOS[@]}"; do
    process_sync "$repo_info" &
    WORKER_PIDS+=($!)
    while [ $(jobs -r | wc -l) -ge $((MAX_PARALLEL + 1)) ]; do
        sleep 0.1
    done
done

wait "${WORKER_PIDS[@]}" 2>/dev/null
exit 0
