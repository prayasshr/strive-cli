#!/bin/bash

# ======================================================================
# STRIVE-SYNC: Mission Control for Your Workspace
# Parallel Repository Synchronizer with Live Dashboard
# Striving Designs | Prayas Shrestha
# ======================================================================

# Resolve the real script location (handles symlinks)
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
    SOURCE=$(readlink "$SOURCE")
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"

if [ -f "$SCRIPT_DIR/../lib/common.sh" ]; then
    source "$SCRIPT_DIR/../lib/common.sh"
else
    echo "Error: lib/common.sh not found (resolved script dir: $SCRIPT_DIR)"
    exit 1
fi

# Version: auto-reads from the nearest git tag when tagged exactly.
# To release a new version: git tag v1.0.2 && git push --tags
_TAGGED=$(git -C "$SCRIPT_DIR" describe --tags --exact-match 2>/dev/null)
VERSION="${_TAGGED#v}"
[ -z "$VERSION" ] && VERSION="1.0.1"

CONFIG_FILE=".repos"
MAX_PARALLEL=4

MISSION_TITLE="STRIVE-SYNC MISSION CONTROL"
BATT_ICON=$(get_power_icon)

# Performance Tracking & Memory
START_TIME=$(perl -e 'use Time::HiRes qw(time); print time' 2>/dev/null || date +%s)

# XDG-compliant state directory (keeps $HOME clean)
MEMORY_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/strive-sync"
MEMORY_FILE="$MEMORY_DIR/last_sync"
mkdir -p "$MEMORY_DIR"

# Secure, isolated temporary directories
STATUS_DIR=$(mktemp -d -t strive_sync.XXXXXX) || exit 1
LOG_DIR=$(mktemp -d -t strive_sync_logs.XXXXXX) || exit 1

if [ -f "$MEMORY_FILE" ]; then
    LAST_TIME=$(awk '{print $1}' "$MEMORY_FILE")
    LAST_STATUS=$(awk '{$1=""; print $0}' "$MEMORY_FILE" | sed 's/^ //')
    rel=$(get_relative_time "$LAST_TIME")
    LAST_MISSION_STR="LAST MISSION: $rel ($LAST_STATUS)"
else
    LAST_MISSION_STR="LAST MISSION: Never"
fi

# Git Background Safety
export GIT_TERMINAL_PROMPT=0
export GIT_SSH_COMMAND="ssh -o BatchMode=yes"

# Surgical Flags
AUTO_INSTALL=false      # Opt-in: -i/--install to run package installs on lockfile changes
FORCE_SYNC=false        # -f/--force to force install regardless of lockfile diff
DRY_RUN=false
BRANCH_OVERRIDDEN=false # true when user passes -b
EXCLUDED_REPOS=()
EXCLUSIVE_REPO=""

# Help Menu
show_help() {
    echo -e "${CYAN}${BOLD}STRIVE-SYNC | v$VERSION${NC} - Workspace Mission Control\n"
    echo -e "Usage: strive-sync [options]"
    echo ""
    echo -e "${YELLOW}${BOLD}Options:${NC}"
    echo -e "  -o, --only <repo>       Sync ONLY this specific repository"
    echo -e "  -e, --exclude <repo>    Exclude a specific repository from syncing"
    echo -e "  -b, --branch <name>     Override auto-detected branch for all repos"
    echo -e "  -d, --dry-run           Show what would be synced without making changes"
    echo -e "  -i, --install           Install dependencies when lockfiles change"
    echo -e "  -f, --force             Force dependency install regardless of lockfile changes"
    echo -e "  -p, --parallel <num>    Max parallel processes (default: 4)"
    echo -e "  -h, --help              Show this help menu"
    echo ""
    echo -e "${CYAN}${BOLD}Discovery:${NC}"
    echo -e "  Run from any directory containing Git repositories."
    echo -e "  Create a ${BOLD}.repos${NC} file for explicit repo:branch control."
    echo ""
    echo -e "  --"
    echo -e "  Built by Prayas Shrestha"
    echo -e "  Discover more at: ${CYAN}strivingdesigns.com${NC}"
    echo ""
}

# Detect the default branch of a repo from the remote's HEAD reference.
# Uses local symbolic-ref first (fast), falls back to a remote query if not set.
detect_default_branch() {
    local repo=$1
    local branch

    # Fast path: reads the symref set by `git remote set-head origin --auto`
    branch=$(git -C "$repo" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|^refs/remotes/origin/||')

    # Slow path: query the remote directly (network call, only if needed)
    if [ -z "$branch" ]; then
        branch=$(git -C "$repo" remote show origin 2>/dev/null | awk '/HEAD branch/ {print $NF}')
    fi

    echo "${branch:-main}"
}

# Individual Repo Processor
process_sync() {
    local repo_info=$1
    local repo=$(echo "$repo_info" | cut -d: -f1)
    local branch_in_file=$(echo "$repo_info" | cut -d: -f2)
    local log_file="$LOG_DIR/$(echo "$repo" | sed 's|/|__|g').log"

    # Determine effective branch with clear precedence:
    # 1. Per-repo branch in .repos file (repo:branch format)
    # 2. Global -b/--branch flag from user
    # 3. Auto-detected from remote (symbolic-ref)
    local branch
    if [ "$branch_in_file" != "$repo" ]; then
        branch="$branch_in_file"
    elif [ "$BRANCH_OVERRIDDEN" == "true" ]; then
        branch="$DEFAULT_BRANCH"
    else
        branch=$(detect_default_branch "$repo")
    fi

    update_status "$repo" "${CYAN}[STARTING]${NC} Initializing..."

    if [ ! -d "$repo" ]; then
        update_status "$repo" "${RED}[MISSING ]${NC} Directory not found"
        return 1
    fi

    local current_branch=$(git -C "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null)

    # Check Dirty State
    if [ -n "$(git -C "$repo" status --short)" ]; then
        update_status "$repo" "${YELLOW}[DIRTY   ]${NC} $current_branch"
        return 0
    fi

    # Fetch Updates
    if [ "$DRY_RUN" == "true" ]; then
        update_status "$repo" "${CYAN}[FETCHING]${NC} (DRY RUN) $branch"
        sleep 0.5
    else
        update_status "$repo" "${CYAN}[FETCHING]${NC} $branch..."
        if ! git -C "$repo" fetch --quiet origin "$branch" 2>"$log_file"; then
            update_status "$repo" "${RED}[FAILED  ]${NC} Fetch error"
            return 1
        fi
    fi

    # Compare and Sync
    LOCAL=$(git -C "$repo" rev-parse HEAD 2>/dev/null)
    UPSTREAM=$(git -C "$repo" rev-parse --abbrev-ref @{u} 2>/dev/null || echo "origin/$branch")
    REMOTE=$(git -C "$repo" rev-parse "$UPSTREAM" 2>/dev/null)

    if [ "$LOCAL" == "$REMOTE" ] && [ "$FORCE_SYNC" == "false" ]; then
        update_status "$repo" "${GREEN}[SYNCED  ]${NC} $branch"
        return 0
    fi

    if [ "$DRY_RUN" == "true" ]; then
        update_status "$repo" "${BLUE}[UPDATING]${NC} (DRY RUN) Merging..."
        sleep 0.5
    elif git -C "$repo" merge-base --is-ancestor "$LOCAL" "$REMOTE" 2>/dev/null; then
        update_status "$repo" "${BLUE}[UPDATING]${NC} Fast-forwarding..."
        git -C "$repo" merge --quiet --ff-only "$UPSTREAM" >> "$log_file" 2>&1
    else
        update_status "$repo" "${RED}[OUT SYNC]${NC} $branch (rebase req)"
        return 1
    fi

    # Dependency Sync — only runs if user opted in via -i or -f
    if [ "$AUTO_INSTALL" == "false" ] && [ "$FORCE_SYNC" == "false" ]; then
        update_status "$repo" "${GREEN}[SUCCESS ]${NC} $branch"
        return 0
    fi

    if ! git -C "$repo" diff --quiet HEAD@{1} HEAD -- yarn.lock package-lock.json pnpm-lock.yaml bun.lockb package.json || [ "$FORCE_SYNC" == "true" ]; then
        if [ "$DRY_RUN" == "true" ]; then
             update_status "$repo" "${PURPLE}[DEPS    ]${NC} (DRY RUN) Installing..."
             sleep 0.5
             update_status "$repo" "${GREEN}[SUCCESS ]${NC} $branch (dry run)"
        else
            NEWEST_LOCK=$(ls -1t "$repo"/yarn.lock "$repo"/package-lock.json "$repo"/pnpm-lock.yaml "$repo"/bun.lockb 2>/dev/null | head -n 1)

            if [[ "$NEWEST_LOCK" == *"yarn.lock" ]]; then
                update_status "$repo" "${PURPLE}[YARN    ]${NC} Installing..."
                (cd "$repo" || return; yarn --silent --non-interactive) >> "$log_file" 2>&1
                update_status "$repo" "${GREEN}[SUCCESS ]${NC} $branch + yarn"
            elif [[ "$NEWEST_LOCK" == *"pnpm-lock.yaml" ]]; then
                update_status "$repo" "${PURPLE}[PNPM    ]${NC} Installing..."
                (cd "$repo" || return; pnpm install --silent) >> "$log_file" 2>&1
                update_status "$repo" "${GREEN}[SUCCESS ]${NC} $branch + pnpm"
            elif [[ "$NEWEST_LOCK" == *"bun.lockb" ]]; then
                update_status "$repo" "${PURPLE}[BUN     ]${NC} Installing..."
                (cd "$repo" || return; bun install --silent) >> "$log_file" 2>&1
                update_status "$repo" "${GREEN}[SUCCESS ]${NC} $branch + bun"
            elif [[ "$NEWEST_LOCK" == *"package-lock.json" ]] || [ -f "$repo/package.json" ]; then
                update_status "$repo" "${PURPLE}[NPM     ]${NC} Installing..."
                (cd "$repo" || return; npm install --silent) >> "$log_file" 2>&1
                update_status "$repo" "${GREEN}[SUCCESS ]${NC} $branch + npm"
            fi
        fi
    else
        update_status "$repo" "${GREEN}[SUCCESS ]${NC} $branch"
    fi
}

# --- Main Entry ---

# Parse args
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -h|--help) show_help; exit 0 ;;
        -p|--parallel) MAX_PARALLEL="$2"; shift ;;
        -b|--branch) DEFAULT_BRANCH="$2"; BRANCH_OVERRIDDEN=true; shift ;;
        -o|--only) EXCLUSIVE_REPO="$2"; shift ;;
        -i|--install) AUTO_INSTALL=true ;;
        -f|--force) FORCE_SYNC=true ;;
        -d|--dry-run) DRY_RUN=true ;;
        -e|--exclude) EXCLUDED_REPOS+=("$2"); shift ;;
        *) echo -e "${RED}Unknown parameter: $1${NC}"; show_help; exit 1 ;;
    esac
    shift
done

# Defaults & Constraints
[ -z "$DEFAULT_BRANCH" ] && DEFAULT_BRANCH="main"

is_excluded() {
    local target="$1"
    for ex in "${EXCLUDED_REPOS[@]}"; do
        [[ "$target" == "$ex" ]] && return 0
    done
    return 1
}

# Discovery
if [ -n "$EXCLUSIVE_REPO" ]; then
    REPOS=("$EXCLUSIVE_REPO")
elif [ -f "$CONFIG_FILE" ]; then
    REPOS=()
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        is_excluded "$line" && continue
        REPOS+=("$line")
    done < "$CONFIG_FILE"
else
    # Space-safe discovery (Bash 3/macOS compatible)
    REPOS=()
    while IFS= read -r dir; do
        is_excluded "$dir" && continue
        REPOS+=("$dir")
    done < <(find . -maxdepth 5 -name ".git" -type d 2>/dev/null | sed 's|/\.git$||' | sed 's|^\./||')
fi

if [ ${#REPOS[@]} -eq 0 ]; then
    echo -e "${YELLOW}No Git repositories found in the current directory.${NC}"
    echo -e "Tip: Run from your workspace root, or create a ${BOLD}.repos${NC} file."
    exit 1
fi

# Init dashboard state
touch "$STATUS_DIR/active"
for repo_info in "${REPOS[@]}"; do
    repo=$(echo "$repo_info" | cut -d: -f1)
    update_status "$repo" "${NC}[WAITING ] Waiting...${NC}"
done

# Start dashboard
render_dashboard &
DASHBOARD_PID=$!

# Trap cleanup
cleanup() {
    kill "${WORKER_PIDS[@]}" 2>/dev/null
    sleep 0.5
    rm -f "$STATUS_DIR/active"
    sleep 0.3
    kill $DASHBOARD_PID 2>/dev/null
    safe_tput cnorm 2>/dev/null

    END_TIME=$(perl -e 'use Time::HiRes qw(time); print time' 2>/dev/null || date +%s)
    ELAPSED=$(echo "$END_TIME - $START_TIME" | bc 2>/dev/null || echo "$((END_TIME - START_TIME))")

    if [[ $ELAPSED == *"."* ]]; then
        ELAPSED=$(printf "%.2f" "$ELAPSED")
    fi

    # Record mission memory (check status files BEFORE deleting them)
    local final_status="Success"
    if [ -d "$STATUS_DIR" ]; then
        if grep -qE '\[FAILED  \]|\[MISSING \]|\[OUT SYNC\]' "$STATUS_DIR"/* 2>/dev/null; then
            final_status="Completed with errors"
        elif grep -q '\[DIRTY   \]' "$STATUS_DIR"/* 2>/dev/null; then
            final_status="Success (Dirty)"
        fi
    fi
    echo "$(date +%s) $final_status" > "$MEMORY_FILE"

    rm -rf "$STATUS_DIR" "$LOG_DIR"

    echo -e "\n${BLUE}────────────────────────────────────────────────────────────${NC}"
    echo -e "${CYAN}${BOLD}MISSION COMPLETE in ${ELAPSED}s${NC}"
}
trap cleanup EXIT INT TERM

# Run Sync Workers
WORKER_PIDS=()
for repo_info in "${REPOS[@]}"; do
    process_sync "$repo_info" &
    WORKER_PIDS+=($!)

    # Limit parallelism
    while [ $(jobs -r | wc -l) -ge $((MAX_PARALLEL + 1)) ]; do
        sleep 0.1
    done
done

# Wait for all workers to finish
wait "${WORKER_PIDS[@]}" 2>/dev/null

exit 0
